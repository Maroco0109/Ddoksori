# =============================================================================
# Database settings
# =============================================================================
# Docker Compose default:
# - Backend container -> DB_HOST=postgres, DB_PORT=5432
# - Host psql/Python -> DB_HOST=127.0.0.1, DB_PORT=${POSTGRES_HOST_PORT:-5433}
# - External M1-5 baseline DB override -> DB_HOST=host.docker.internal, DB_PORT=5432
# - Production/RDS override -> DB_HOST=<rds-endpoint>, DB_USER/DB_PASSWORD=<secret>
#
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ddoksori
DB_USER=postgres
DB_PASSWORD=postgres
POSTGRES_HOST_PORT=5433

# =============================================================================
# LLM API 키
# =============================================================================
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# 모델 설정 (MAS Agent별 LLM 모델)
# =============================================================================
MODEL_SUPERVISOR=gpt-4o
MODEL_DRAFT_AGENT=gpt-4o
MODEL_REVIEW_AGENT=gpt-4o
MODEL_QUERY_CLASSIFIER=gpt-4o-mini
MODEL_QUERY_EXPANDER=gpt-4o-mini

# =============================================================================
# EXAONE vLLM 설정
# =============================================================================
# RunPod SSH 터널링 시: http://localhost:19080/v1
# RunPod Proxy URL 시: https://<pod-id>-9080.proxy.runpod.net/v1
EXAONE_RUNPOD_URL=http://localhost:19080/v1
EXAONE_RUNPOD_API_KEY=dummy
EXAONE_MODEL=LGAI-EXAONE/EXAONE-3.5-7.8B-Instruct
EXAONE_MODEL_SIZE=7.8B
EXAONE_TEMPERATURE=0.3
EXAONE_MAX_TOKENS=1024
EXAONE_TIMEOUT=10

# MAS용 EXAONE 4.0 설정
MODEL_EXAONE_BASE_URL=http://localhost:19010/v1
MODEL_EXAONE_API_KEY=empty
MODEL_EXAONE_NAME=LG-AI-EXAONE/EXAONE-4.0-1.2B-Instruct
PORT_EXAONE_VLLM=19010

# =============================================================================
# 임베딩 설정 (OpenAI only)
# =============================================================================
EMBEDDING_MODEL=text-embedding-3-large

# =============================================================================
# 애플리케이션 설정
# =============================================================================
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=True
RETRIEVAL_MODE=hybrid

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 서비스 URL
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# =============================================================================
# 에이전트 튜닝
# =============================================================================
# 유사도 임계값 (도메인별)
SIMILARITY_THRESHOLD=0.55
SIMILARITY_THRESHOLD_DISPUTE=0.55
SIMILARITY_THRESHOLD_LAW=0.60
SIMILARITY_THRESHOLD_CRITERIA=0.50
SIMILARITY_THRESHOLD_GENERAL=0.45

# Legal Review 설정
PROHIBITED_VIOLATION_THRESHOLD=3
MAX_REVIEW_RETRIES=2
ENABLE_LLM_REVIEW=false

# =============================================================================
# Redis 캐싱 설정
# =============================================================================
# Redis: 'redis' for Docker Compose, 'localhost' for local
ENABLE_ANSWER_CACHE=false
ENABLE_EMBEDDING_CACHE=false
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# Local compose default only. Override in production/secrets.
REDIS_PASSWORD=dev_redis_password_change_in_production

# 캐시 TTL
SUPERVISOR_CACHE_TTL_SECONDS=3600
QA_CACHE_TTL_SECONDS=86400
ANSWER_CACHE_TTL_HOURS=24
CACHE_LOG_LEVEL=INFO

# =============================================================================
# 대화 메모리 설정
# =============================================================================
# memory: 인메모리 (기본), db: PostgreSQL 영구 저장
CONVERSATION_MEMORY_BACKEND=db
MAX_CONVERSATION_TURNS=30
SLIDING_WINDOW_SIZE=10
GUEST_SESSION_TTL_HOURS=24
CLEANUP_INTERVAL_HOURS=1

# =============================================================================
# 대화형 챗봇 기능 플래그
# =============================================================================
ANSWER_FORMAT_MODE=flexible
ENABLE_FOLLOWUP_QUESTIONS=true

# =============================================================================
# 응답 처리 방식 (Progressive Disclosure A/B 테스트)
# =============================================================================
# legacy: 기존 동작 (모든 정보 한 번에 출력)
# minimal: 규칙 기반 요약 응답 + 후속 질문
# adaptive: LLM 기반 적응형 응답
RESPONSE_MODE=legacy
SUMMARY_MAX_LENGTH=200
FOLLOWUP_SIMILARITY_THRESHOLD=0.8
META_QUERY_USE_LLM=false

# =============================================================================
# JWT 인증 설정
# =============================================================================
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_TOKEN_EXPIRE_DAYS=30

# =============================================================================
# OAuth 2.0 소셜 로그인
# =============================================================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# =============================================================================
# 선택사항: LangSmith 추적
# =============================================================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=ddoksori

# =============================================================================
# 보안 주의사항
# =============================================================================
# - 이 파일(.env)을 Git에 커밋하지 마세요
# - 프로덕션: AWS Secrets Manager / Docker Secrets 사용 권장
# - API 키는 개발/프로덕션용 분리, 정기 로테이션
