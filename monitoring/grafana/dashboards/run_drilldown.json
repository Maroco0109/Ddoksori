{
  "uid": "ddoksori-run-drilldown",
  "title": "DDOKSORI Run Drilldown",
  "tags": ["ddoksori", "m6"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "",
  "time": { "from": "now-30d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "variant",
        "label": "variant",
        "type": "custom",
        "query": "All : %, A : A, B : B",
        "current": { "text": "All", "value": "%" },
        "includeAll": false,
        "multi": false
      },
      {
        "name": "status",
        "label": "status",
        "type": "custom",
        "query": "All : %, success : success, error : error",
        "current": { "text": "All", "value": "%" },
        "includeAll": false,
        "multi": false
      },
      {
        "name": "run_id",
        "label": "run_id",
        "type": "query",
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "ddoksori-postgres" },
        "query": "SELECT run_id FROM workflow_runs WHERE variant LIKE '$variant' AND status LIKE '$status' ORDER BY created_at DESC LIMIT 200",
        "refresh": 2,
        "sort": 0,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Runs (filter: variant=$variant status=$status; pick a run_id above)",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "ddoksori-postgres" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "ddoksori-postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT created_at, run_id, variant, status, round(total_time_ms) AS ms, clarified, blocked, left(query, 60) AS query FROM workflow_runs WHERE variant LIKE '$variant' AND status LIKE '$status' AND $__timeFilter(created_at) ORDER BY created_at DESC LIMIT 200"
        }
      ]
    },
    {
      "id": 2,
      "type": "table",
      "title": "Steps (workflow_steps) — run_id=$run_id",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "ddoksori-postgres" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "ddoksori-postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT seq, step_name, category, round(duration_ms) AS ms FROM workflow_steps WHERE run_id = '$run_id' ORDER BY seq"
        }
      ]
    },
    {
      "id": 3,
      "type": "table",
      "title": "Retrieval (retrieval_events) — run_id=$run_id",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "ddoksori-postgres" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "ddoksori-postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT seq, source, domain, top_k, result_count, round(max_similarity::numeric, 3) AS max_sim, round(avg_similarity::numeric, 3) AS avg_sim FROM retrieval_events WHERE run_id = '$run_id' ORDER BY seq"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "LLM calls (llm_calls) — run_id=$run_id",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "ddoksori-postgres" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "ddoksori-postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT seq, component, provider, model, prompt_tokens, completion_tokens, total_tokens, n_calls, status FROM llm_calls WHERE run_id = '$run_id' ORDER BY seq"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Guardrail (guardrail_events) — run_id=$run_id",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "ddoksori-postgres" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "ddoksori-postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT seq, stage, source, decision, reason FROM guardrail_events WHERE run_id = '$run_id' ORDER BY seq"
        }
      ]
    }
  ]
}
