# =============================================================================
# 데이터베이스 설정
# =============================================================================
# Local Docker DB (기본):
#   DB_HOST=db (docker-compose 내부 서비스명)
#   DB_HOST=localhost (로컬 직접 실행 시)
#
# AWS RDS 사용 시:
#   DB_HOST=your-instance.xxxx.ap-northeast-2.rds.amazonaws.com
#   docker compose -f docker-compose.yml -f docker-compose.rds.yml up --build
#
DB_HOST=db
DB_PORT=5432
DB_NAME=ddoksori
DB_USER=postgres
DB_PASSWORD=postgres

# LLM API 키 (PR #3 이후 사용)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 임베딩 모델 설정 (PR #2에서 사용)
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=1536

# 애플리케이션 설정
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=True
SECRET_KEY=your_secret_key_here
RETRIEVAL_MODE=hybrid

# CORS 설정
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# LangSmith 설정 (PR #8 이후 사용, 선택사항)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=ddoksori

# HuggingFace Token 설정 (SPLADE)
HF_TOKEN=your_huggingface_token

# =============================================================================
# 임베딩 서버 설정 (KURE-v1)
# =============================================================================
# RunPod SSH 터널링 시: http://localhost:19001
# RunPod Proxy URL 시: https://<pod-id>-9001.proxy.runpod.net
REMOTE_EMBED_URL=http://localhost:19001

# Docker/Dev convenience: avoid blocking API startup.
DISABLE_LOCAL_EMBED_AUTO_START=true

# 로컬 서버 포트 (기본: 9001)
KURE_LOCAL_PORT=9001

# =============================================================================
# EXAONE 3.5 LLM 설정 (S2-8, S3-PR2)
# =============================================================================
# RunPod SSH 터널링 시: http://localhost:19080/v1
# RunPod Proxy URL 시: https://<pod-id>-9080.proxy.runpod.net/v1
EXAONE_RUNPOD_URL=http://localhost:19080/v1
EXAONE_RUNPOD_API_KEY=dummy

# 모델 선택
# - LGAI-EXAONE/EXAONE-3.5-2.4B-Instruct: 소형 모델 (16GB GPU)
# - LGAI-EXAONE/EXAONE-3.5-7.8B-Instruct: 중형 모델 (24GB GPU, 권장)
# - LGAI-EXAONE/EXAONE-3.5-32B-Instruct: 대형 모델 (80GB GPU)
EXAONE_MODEL=LGAI-EXAONE/EXAONE-3.5-7.8B-Instruct

# 모델 크기 (자동 파라미터 조정용, 선택사항)
# - 2.4B, 7.8B, 32B 중 하나
EXAONE_MODEL_SIZE=7.8B

# LLM 파라미터 (7.8B 모델 기본값)
# - 2.4B: temperature=0.1, max_tokens=512
# - 7.8B: temperature=0.3, max_tokens=1024
# - 32B: temperature=0.3, max_tokens=2048
EXAONE_TEMPERATURE=0.3
EXAONE_MAX_TOKENS=1024
EXAONE_TIMEOUT=10

# ReAct 추론 모드 (llm | rule)
# - llm: EXAONE LLM 기반 추론 (RunPod 필요)
# - rule: 규칙 기반 추론 (기본값)
REACT_THINK_MODE=rule

# ReAct LLM 재시도 설정 (S1-PR2)
# - 파싱 실패, 일시적 오류 시 재시도
# - LLM 서버 불가 시에는 재시도 없이 규칙 기반 폴백
REACT_LLM_MAX_RETRIES=2
REACT_LLM_RETRY_DELAY_MS=100

# =============================================================================
# 하이브리드 도구 선택 설정 (S3-PR3)
# =============================================================================
# LLM 기반 @tool calling 활성화 (기본: false)
# - false: 규칙 기반 도구 선택 (ActionRegistry, 기본값)
# - true: LLM 기반 동적 도구 선택 (vLLM tool calling)
#         실패/타임아웃 시 규칙 기반으로 자동 폴백
USE_LLM_TOOLS=false

# LLM 도구 선택 타임아웃 (밀리초, 기본: 5000ms)
# - 타임아웃 초과 시 규칙 기반 도구 선택으로 폴백
LLM_TOOL_TIMEOUT_MS=5000

# =============================================================================
# 에이전트 공통 설정 (S1-PR3)
# =============================================================================
# 유사도 임계값 (기본값: 0.55)
# - 검색 결과의 유사도가 이 값 이상이면 "관련성 높음"으로 판단
SIMILARITY_THRESHOLD=0.55

# 쿼리 타입별 유사도 임계값 (선택적)
# - 쿼리 유형에 따라 다른 임계값 적용 가능
SIMILARITY_THRESHOLD_DISPUTE=0.55
SIMILARITY_THRESHOLD_LAW=0.60
SIMILARITY_THRESHOLD_CRITERIA=0.50
SIMILARITY_THRESHOLD_GENERAL=0.45

# ReAct 최대 반복 횟수 (기본값: 2)
# - 검색 결과 불충분 시 추가 검색 최대 횟수
MAX_REACT_ITERATIONS=2

# Legal Review 설정
# - 금지 표현 위반 임계값: 이 수 이상이면 재생성 필요
PROHIBITED_VIOLATION_THRESHOLD=3
# - 최대 재생성 시도 횟수
MAX_REVIEW_RETRIES=2
# - LLM 기반 법률 검토 활성화 (S2-PR2)
#   규칙 기반 검토 통과 시 LLM으로 추가 검토
#   프로덕션에서는 점진적 활성화 권장
ENABLE_LLM_REVIEW=false

# =============================================================================
# Redis 답변 캐싱 설정 (S2-PR3)
# =============================================================================
# 캐싱 활성화 (기본: false)
# - true로 설정 시 유사 질문에 대해 캐시된 답변 반환
# - Redis 연결 실패 시 자동으로 캐시 없이 동작 (graceful degradation)
ENABLE_ANSWER_CACHE=false

# Redis 연결 설정
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# 캐시 TTL (시간 단위, 기본: 24시간)
ANSWER_CACHE_TTL_HOURS=24

# =============================================================================
# OpenAI 임베딩 설정 (S3-PR1)
# =============================================================================
# OpenAI text-embedding-3-large 사용 여부
# - false: 기존 KURE-v1 사용 (기본값, Phase 1)
# - true: OpenAI API 사용 (Phase 2, Sprint R 이후)
USE_OPENAI_EMBEDDING=true

# 차원은 1536으로 고정 (코드에서 설정, 환경 변수로 변경 불가)
# - text-embedding-3-small과 동일 차원
# - 94.8% Recall@10 성능
# - Sprint R 이후 DB 스키마 변경 필요 (1024 → 1536)

# =============================================================================
# BGE-M3 임베딩 설정 (S2-9)
# =============================================================================
# BGE-M3 서버 URL (Dense + Sparse 임베딩)
# RunPod SSH 터널링 시: http://localhost:19003
# RunPod Proxy URL 시: https://<pod-id>-9003.proxy.runpod.net
BGE_M3_REMOTE_URL=http://localhost:19003
BGE_M3_LOCAL_PORT=9003

# 활성 임베딩 모델 선택
# - kure-v1: 기존 KURE-v1 Dense 모델 (기본값)
# - bge-m3: BGE-M3 Dense + Sparse 모델
EMBEDDING_MODEL=kure-v1

# Sparse 검색 활성화 (BGE-M3 필요)
# true로 설정 시 3-way RRF (Dense + Lexical + Sparse)
EMBEDDING_MODEL=text-embedding-3-large

# RRF 가중치 파라미터 (A/B 테스트용)
# 기본값: 1:1:1 동등 가중치
RRF_WEIGHT_DENSE=1.0
RRF_WEIGHT_LEXICAL=1.0
RRF_WEIGHT_SPARSE=1.0

# =============================================================================
# LLM 기반 쿼리 재작성 설정 (S2-10)
# =============================================================================
# 쿼리 재작성 기능 활성화 (true | false)
# - true: 복잡한 법률 용어 쿼리를 EXAONE으로 일상어 변환 (기본값)
#         EXAONE 불가 시 규칙 기반으로 자동 폴백
# - false: 규칙 기반 쿼리 확장만 사용
QUERY_REWRITE_ENABLED=true

# 캐시 크기 (LRU 캐시, 기본: 1000)
# - 자주 사용되는 쿼리 재작성 결과를 캐싱하여 지연시간 감소
QUERY_REWRITE_CACHE_SIZE=1000

# LLM 호출 타임아웃 (밀리초, 기본: 90ms)
# - 타임아웃 초과 시 규칙 기반 확장으로 폴백
QUERY_REWRITE_TIMEOUT=90

# 총 쿼리 재작성 지연시간 예산 (밀리초, 기본: 100ms)
QUERY_REWRITE_TOTAL_BUDGET=100

# LLM 재작성 트리거 최소 복잡도 (기본: 1)
# - 법률 용어가 이 개수 이상 포함되면 LLM 재작성 시도
QUERY_REWRITE_MIN_COMPLEXITY=1

# =============================================================================
# MAS Supervisor 그래프 설정 (Phase 6 → 운영 전환 완료)
# =============================================================================
# MAS Supervisor 그래프 전환 플래그
# - true: MAS Supervisor 그래프 사용 (기본값, Phase 7 이후)
# - false: 기존 Unified ReAct 그래프 사용 (롤백용, deprecated)
MAS_SUPERVISOR_ENABLED=true

# Canary 배포 비율 (0-100)
# - 0: Canary 비활성화 (기본값, 전체 전환 완료 후)
# - 10: 10% 트래픽에 MAS 그래프 적용
# - 세션 ID 해시 기반으로 일관된 라우팅 보장
MAS_SUPERVISOR_CANARY_PERCENT=0

# =============================================================================
# 모델 아키텍처 설정 (MAS Agent별 LLM 모델)
# =============================================================================
# 각 에이전트에서 사용할 LLM 모델을 중앙 관리합니다.
# 환경변수로 오버라이드 가능하며, 기본값은 최적화된 모델 조합입니다.
#
# MODEL_SUPERVISOR: Supervisor 에이전트 (라우팅/조율)
MODEL_SUPERVISOR=gpt-5.1

# MODEL_DRAFT_AGENT: Draft 에이전트 (초안 생성)
MODEL_DRAFT_AGENT=gpt-4o

# MODEL_REVIEW_AGENT: Review 에이전트 (법률 검토)
MODEL_REVIEW_AGENT=gpt-4o

# MODEL_RETRIEVAL_LLM: Retrieval LLM (검색 쿼리 생성)
MODEL_RETRIEVAL_LLM=LGAI-EXAONE/EXAONE-4.0-1.2B

# MODEL_RETRIEVAL_FALLBACK: Retrieval 폴백 모델 (EXAONE 불가 시)
MODEL_RETRIEVAL_FALLBACK=gpt-4.1-nano

# =============================================================================
# Retrieval Agent별 EXAONE URL 설정 (병렬 처리용)
# =============================================================================
# 각 Retrieval Agent가 독립된 EXAONE vLLM 인스턴스를 사용하도록 설정합니다.
# 설정하지 않으면 공통 EXAONE_RUNPOD_URL을 사용합니다 (싱글톤 fallback).
#
# 4개 인스턴스 사용 시 진정한 병렬 처리 가능:
#   - 현재: 4개 에이전트 → 1개 EXAONE → 순차 처리 (최대 12초)
#   - 개선: 4개 에이전트 → 4개 EXAONE → 병렬 처리 (최대 3초)
#
# RETRIEVAL_LLM_LAW_URL=http://localhost:19010/v1
# RETRIEVAL_LLM_CRITERIA_URL=http://localhost:19011/v1
# RETRIEVAL_LLM_CASE_URL=http://localhost:19012/v1
# RETRIEVAL_LLM_COUNSEL_URL=http://localhost:19013/v1

# Query Rewrite 타임아웃 (초)
RETRIEVAL_LLM_TIMEOUT=3.0

# EXAONE vLLM 설정
MODEL_EXAONE_BASE_URL=http://localhost:19010/v1
MODEL_EXAONE_API_KEY=empty
MODEL_EXAONE_NAME=LG-AI-EXAONE/EXAONE-4.0-1.2B-Instruct

# =============================================================================
# 서비스 포트 설정
# =============================================================================
# vLLM, 임베딩 서버 등 외부 서비스 포트를 중앙 관리합니다.
#
# PORT_EXAONE_VLLM: EXAONE vLLM 서버 포트 (SSH 터널링 시)
PORT_EXAONE_VLLM=19010

# =============================================================================
# RDS 테스트 환경 설정 (READ_ONLY 계정)
# =============================================================================
# 통합 테스트에서 실제 RDS 데이터를 사용할 때 설정합니다.
# READ_ONLY 계정으로 안전하게 테스트할 수 있습니다.
#
# 주의사항:
# - DB_TEST_USER는 반드시 READ_ONLY 권한만 가진 계정을 사용하세요
# - 실제 비밀번호를 .env.example에 커밋하지 마세요
# - USE_RDS_FOR_TESTS=true 설정 시에만 RDS 연결 사용
#
# DB_TEST_HOST: RDS 엔드포인트
DB_TEST_HOST=your-instance.xxxx.region.rds.amazonaws.com

# DB_TEST_USER: READ_ONLY 계정 (WRITE 권한 없음)
DB_TEST_USER=readonly_user

# DB_TEST_PASSWORD: READ_ONLY 계정 비밀번호
DB_TEST_PASSWORD=your_readonly_password

# DB_TEST_NAME: 테스트 대상 데이터베이스
DB_TEST_NAME=ddoksori

# USE_RDS_FOR_TESTS: RDS 테스트 활성화 플래그
# - false: 로컬 DB 사용 (기본값)
# - true: RDS READ_ONLY 연결 사용
USE_RDS_FOR_TESTS=false

# =============================================================================
# 보안 주의사항
# =============================================================================
# 
# ⚠️ 이 파일(.env)을 Git에 커밋하지 마세요!
# ⚠️ 프로덕션 환경에서는 강력한 비밀번호를 사용하세요!
# ⚠️ API 키는 개발용과 프로덕션용을 분리하세요!
# ⚠️ 정기적으로 키를 로테이션하세요!
# ⚠️ Docker Inspect로 환경변수가 노출될 수 있으니 주의하세요!
#
# 프로덕션 배포 시에는 다음 중 하나를 사용하세요:
# - Docker Secrets (Docker Swarm)
# - Kubernetes Secrets (K8s)
# - AWS Secrets Manager / Azure Key Vault (클라우드)
#
# =============================================================================
