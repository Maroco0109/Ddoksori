FROM python:3.11-slim

WORKDIR /app

# 시스템 패키지 설치 (curl은 healthcheck에 필요)
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Python 패키지 (임베딩에 필요한 최소 패키지만)
RUN pip install --no-cache-dir \
    fastapi==0.115.6 \
    uvicorn[standard]==0.32.1 \
    sentence-transformers==3.3.1 \
    torch==2.5.1 \
    numpy==2.2.1

# 임베딩 서버 코드
# Reuse the repo's embedding server implementation.
COPY app/agents/retrieval/services/embedding_server.py ./embedding_server.py

EXPOSE 8001

# CPU 모드로 실행 (CUDA_VISIBLE_DEVICES 비활성화)
ENV CUDA_VISIBLE_DEVICES=""

CMD ["uvicorn", "embedding_server:app", "--host", "0.0.0.0", "--port", "8001"]
